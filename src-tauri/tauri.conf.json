{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gemini Desktop",
  "version": "2.1.0",
  "identifier": "com.omux2.geminidesktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Gemini Desktop",
        "width": 600,
        "height": 800,
        "decorations": false,
        "visible": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/Omux25/gemini-desktop/main/updater.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE4QzY5ODQ1OTI1MEQyNjMKUldSajBsQ1NSWmpHcU9PWEJmbGdBdHR0N3poV0NVWmpjZ1paeGtqSERoTmJCdG9JOUg1REZwcFEK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}


